{
  "name": "lila-core",
  "version": "1.0.0",
  "description": "Working-memory consolidation engine for Lila. Reads recent activity from Supabase, distills it into a structured working_memory record using Claude, writes it back. Open source.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "wm:consolidate": "tsx scripts/working-memory-consolidate.ts",
    "wm:consolidate:supabase": "tsx scripts/working-memory-consolidate-supabase.ts",
    "wm:consolidate:all": "tsx scripts/working-memory-consolidate-all.ts",
    "gcal:sync": "tsx scripts/gcal-sync.ts",
    "gcal:oauth:mint": "tsx scripts/gcal-oauth-mint.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@supabase/supabase-js": "^2.105.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
